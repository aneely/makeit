#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

config_home() {
  echo "${XDG_CONFIG_HOME:-$HOME/.config}/makeit"
}

sources_file() {
  echo "$(config_home)/sources"
}

# Reads the sources file and prints each directory, one per line.
# Expands ~ to $HOME. Skips blank lines and comments.
config_dirs() {
  local sf
  sf="$(sources_file)"
  [[ -f "$sf" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"          # strip comments
    line="${line#"${line%%[! ]*}"}"  # trim leading spaces
    line="${line%"${line##*[! ]}"}"  # trim trailing spaces
    [[ -z "$line" ]] && continue
    echo "${line/#\~/$HOME}"
  done < "$sf"
}

# ---------------------------------------------------------------------------
# Argument classification
# ---------------------------------------------------------------------------

is_file_path() {
  local arg="$1"
  [[ "$arg" == *.lua || "$arg" == */* || "$arg" == .* || "$arg" == ~* ]]
}

# ---------------------------------------------------------------------------
# Path resolution
# ---------------------------------------------------------------------------

resolve_file_path() {
  local arg="$1"
  local path="${arg/#\~/$HOME}"
  [[ "$path" != /* ]] && path="$PWD/$path"
  echo "$path"
}

# Searches sources for <name>.lua; prints the first match.
# Returns 1 if not found.
resolve_profile_path() {
  local name="$1"
  local dir
  while IFS= read -r dir; do
    if [[ -f "$dir/$name.lua" ]]; then
      echo "$dir/$name.lua"
      return 0
    fi
  done < <(config_dirs)
  return 1
}

# ---------------------------------------------------------------------------
# Guards
# ---------------------------------------------------------------------------

require_sources() {
  local sf
  sf="$(sources_file)"
  if [[ ! -f "$sf" ]]; then
    echo "makeit: no sources file found at $sf" >&2
    echo "  Run: makeit init" >&2
    exit 1
  fi
  local has_dir=false
  local dir
  while IFS= read -r dir; do
    if [[ -d "$dir" ]]; then
      has_dir=true
      break
    fi
  done < <(config_dirs)
  if [[ "$has_dir" == false ]]; then
    echo "makeit: no valid source directories found in $sf" >&2
    exit 1
  fi
}

require_hammerspoon() {
  if ! command -v hs >/dev/null 2>&1; then
    echo "makeit: hs not found. Open Hammerspoon → Console and run: hs.ipc.cliInstall()" >&2
    exit 1
  fi
  if ! pgrep -x Hammerspoon >/dev/null 2>&1; then
    echo "makeit: Hammerspoon is not running. Launch it and try again." >&2
    exit 1
  fi
}

require_file() {
  local path="$1" label="$2"
  if [[ ! -f "$path" ]]; then
    echo "makeit: $label not found: $path" >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_list() {
  require_sources
  shopt -s nullglob
  local found=false
  local seen=" "
  local dir name
  while IFS= read -r dir; do
    for p in "$dir"/*.lua; do
      found=true
      name="$(basename "$p" .lua)"
      if [[ "$seen" == *" $name "* ]]; then
        printf "%-20s %s  [shadowed]\n" "$name" "$dir"
      else
        printf "%-20s %s\n" "$name" "$dir"
        seen+="$name "
      fi
    done
  done < <(config_dirs)
  if [[ "$found" == false ]]; then
    echo "makeit: no profiles found in any source directory" >&2
    exit 1
  fi
}

cmd_clear() {
  local path
  if ! path="$(resolve_profile_path clear)"; then
    echo "makeit: no clear.lua found in any source directory" >&2
    exit 1
  fi
  run_profile "$path"
}

cmd_file() {
  local arg="$1"
  local path
  path="$(resolve_file_path "$arg")"
  if [[ ! -f "$path" ]]; then
    echo "makeit: file not found: $arg" >&2
    exit 1
  fi
  run_profile "$path"
}

cmd_profile() {
  require_sources
  local path
  if ! path="$(resolve_profile_path "$1")"; then
    echo "makeit: profile not found: $1" >&2
    list_available_profiles
    exit 1
  fi
  run_profile "$path"
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Prints available profiles to stderr. Used when a named profile is not found.
list_available_profiles() {
  shopt -s nullglob
  local found=false
  local dir
  while IFS= read -r dir; do
    for p in "$dir"/*.lua; do
      if [[ "$found" == false ]]; then
        echo "available profiles:" >&2
        found=true
      fi
      echo "  $(basename "$p" .lua)" >&2
    done
  done < <(config_dirs)
}

# ---------------------------------------------------------------------------
# Execution
# ---------------------------------------------------------------------------

run_profile() {
  local path="$1"
  local dir
  dir="$(dirname "$path")"
  require_hammerspoon
  hs -c "MAKEIT_CONFIG=[=[$dir]=]; dofile([=[$path]=])"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  echo "usage: makeit <profile>    run a profile from config dir" >&2
  echo "       makeit <file.lua>   run any .lua file directly" >&2
  echo "       makeit list         list available profiles" >&2
  echo "       makeit clear        run clear.lua from config dir" >&2
  exit 1
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  local cmd="${1:-}"
  [[ -z "$cmd" ]] && usage

  case "$cmd" in
    list)  cmd_list ;;
    clear) cmd_clear ;;
    *)
      if is_file_path "$cmd"; then
        cmd_file "$cmd"
      else
        cmd_profile "$cmd"
      fi
      ;;
  esac
}

main "$@"
